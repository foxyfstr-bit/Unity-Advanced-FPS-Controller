using UnityEngine;
using UnityEngine.Serialization;

[RequireComponent(typeof(CharacterController))]
public sealed class PlayerMovement : MonoBehaviour
{
    [Header("References")]
    [Tooltip("The camera used for vertical mouse look. If empty, Camera.main is used.")]
    [SerializeField] private Transform playerCamera;

    [Header("Movement Settings")]
    [FormerlySerializedAs("moveSpeed")]
    [SerializeField, Min(0f)] private float walkSpeed = 5f;

    [SerializeField, Min(0f)] private float sprintSpeed = 8f;

    [Tooltip("How quickly the player reaches their target movement speed.")]
    [SerializeField, Min(0f)] private float groundAcceleration = 35f;

    [Tooltip("How quickly the player stops when movement input is released.")]
    [SerializeField, Min(0f)] private float groundDeceleration = 45f;

    [Tooltip("How much control the player has while airborne.")]
    [SerializeField, Range(0f, 1f)] private float airControl = 0.35f;

    [Header("Jump Settings")]
    [SerializeField, Min(0f)] private float jumpHeight = 1.5f;

    [Tooltip("Positive gravity strength. It is applied downward automatically.")]
    [SerializeField, Min(0f)] private float gravity = 25f;

    [Tooltip("Small downward force that keeps the controller attached to the ground.")]
    [SerializeField, Min(0f)] private float groundedForce = 2f;

    [SerializeField, Min(0f)] private float terminalVelocity = 50f;

    [Tooltip("How long after walking off a ledge the player can still jump.")]
    [SerializeField, Range(0f, 0.5f)] private float coyoteTime = 0.12f;

    [Tooltip("How early the player can press jump before landing.")]
    [SerializeField, Range(0f, 0.5f)] private float jumpBufferTime = 0.12f;

    [Tooltip("Reduces upward velocity when Space is released early.")]
    [SerializeField, Range(0f, 1f)] private float jumpCutMultiplier = 0.5f;

    [Header("Camera Settings")]
    [SerializeField, Min(0f)] private float mouseSensitivity = 2f;

    [SerializeField, Range(1f, 90f)] private float upDownLookLimit = 80f;

    [SerializeField] private bool invertVerticalLook;

    private CharacterController controller;

    private Vector3 horizontalVelocity;
    private float verticalVelocity;
    private float verticalRotation;

    private float coyoteTimer;
    private float jumpBufferTimer;

    /// <summary>
    /// Whether the controller was grounded during the latest movement update.
    /// Useful for animation or other scripts.
    /// </summary>
    public bool IsGrounded { get; private set; }

    /// <summary>
    /// Whether the player is currently trying to sprint.
    /// </summary>
    public bool IsSprinting { get; private set; }

    /// <summary>
    /// Approximate velocity calculated by this movement controller.
    /// </summary>
    public Vector3 Velocity =>
        horizontalVelocity + Vector3.up * verticalVelocity;

    private void Awake()
    {
        controller = GetComponent<CharacterController>();

        // Automatically find the tagged Main Camera if one was not assigned.
        if (playerCamera == null && Camera.main != null)
        {
            playerCamera = Camera.main.transform;
        }
    }

    private void Start()
    {
        if (playerCamera != null)
        {
            // Preserve the camera's existing starting rotation.
            verticalRotation = NormalizeAngle(
                playerCamera.localEulerAngles.x
            );
        }
        else
        {
            Debug.LogWarning(
                $"{nameof(PlayerMovement)} on {name} could not find a player camera.",
                this
            );
        }

        // Cursor starts locked, as in the original script.
        LockCursor();
    }

    private void Update()
    {
        HandleCursorToggle();
        HandleMouseLook();
        HandleMovement();
    }

    private void HandleMouseLook()
    {
        // Looking is disabled while the cursor is unlocked.
        if (playerCamera == null ||
            Cursor.lockState != CursorLockMode.Locked)
        {
            return;
        }

        float mouseX =
            Input.GetAxis("Mouse X") * mouseSensitivity;

        float mouseY =
            Input.GetAxis("Mouse Y") * mouseSensitivity;

        // Horizontal rotation turns the entire player.
        transform.Rotate(0f, mouseX, 0f);

        // Vertical rotation only turns the camera.
        float verticalInput = invertVerticalLook
            ? mouseY
            : -mouseY;

        verticalRotation += verticalInput;

        verticalRotation = Mathf.Clamp(
            verticalRotation,
            -upDownLookLimit,
            upDownLookLimit
        );

        playerCamera.localRotation = Quaternion.Euler(
            verticalRotation,
            0f,
            0f
        );
    }

    private void HandleMovement()
    {
        float deltaTime = Time.deltaTime;

        IsGrounded = controller.isGrounded;

        UpdateJumpTimers(deltaTime);

        Vector2 movementInput = new Vector2(
            Input.GetAxisRaw("Horizontal"),
            Input.GetAxisRaw("Vertical")
        );

        // Prevent diagonal movement from being faster.
        movementInput = Vector2.ClampMagnitude(movementInput, 1f);

        bool hasMovementInput =
            movementInput.sqrMagnitude > 0.001f;

        IsSprinting =
            Input.GetKey(KeyCode.LeftShift) &&
            hasMovementInput;

        float targetSpeed =
            IsSprinting ? sprintSpeed : walkSpeed;

        Vector3 desiredDirection =
            transform.right * movementInput.x +
            transform.forward * movementInput.y;

        Vector3 desiredVelocity =
            desiredDirection * targetSpeed;

        UpdateHorizontalVelocity(
            desiredVelocity,
            hasMovementInput,
            deltaTime
        );

        UpdateVerticalVelocity(deltaTime);

        Vector3 finalVelocity =
            horizontalVelocity +
            Vector3.up * verticalVelocity;

        CollisionFlags collisionFlags =
            controller.Move(finalVelocity * deltaTime);

        // Immediately stop upward movement when hitting a ceiling.
        if ((collisionFlags & CollisionFlags.Above) != 0 &&
            verticalVelocity > 0f)
        {
            verticalVelocity = 0f;
        }

        // Update this after movement so external scripts get
        // the most recent grounded state possible.
        if ((collisionFlags & CollisionFlags.Below) != 0)
        {
            IsGrounded = true;
        }
    }

    private void UpdateHorizontalVelocity(
        Vector3 desiredVelocity,
        bool hasMovementInput,
        float deltaTime
    )
    {
        if (IsGrounded)
        {
            float acceleration = hasMovementInput
                ? groundAcceleration
                : groundDeceleration;

            horizontalVelocity = Vector3.MoveTowards(
                horizontalVelocity,
                desiredVelocity,
                acceleration * deltaTime
            );

            return;
        }

        // Air movement can steer the player but does not instantly
        // remove momentum when movement input is released.
        if (hasMovementInput)
        {
            float airAcceleration =
                groundAcceleration * airControl;

            horizontalVelocity = Vector3.MoveTowards(
                horizontalVelocity,
                desiredVelocity,
                airAcceleration * deltaTime
            );
        }
    }

    private void UpdateVerticalVelocity(float deltaTime)
    {
        // Keep the CharacterController pressed gently against the ground.
        if (IsGrounded && verticalVelocity < 0f)
        {
            verticalVelocity = -groundedForce;
        }

        bool canUseBufferedJump =
            jumpBufferTimer > 0f &&
            coyoteTimer > 0f;

        if (canUseBufferedJump)
        {
            // Calculates the velocity required to reach jumpHeight.
            verticalVelocity = Mathf.Sqrt(
                jumpHeight * 2f * gravity
            );

            // Consume both timers so one press cannot trigger twice.
            jumpBufferTimer = 0f;
            coyoteTimer = 0f;
            IsGrounded = false;
        }

        // Releasing Space early creates a shorter jump.
        if (Input.GetKeyUp(KeyCode.Space) &&
            verticalVelocity > 0f)
        {
            verticalVelocity *= jumpCutMultiplier;
        }

        verticalVelocity -= gravity * deltaTime;

        verticalVelocity = Mathf.Max(
            verticalVelocity,
            -terminalVelocity
        );
    }

    private void UpdateJumpTimers(float deltaTime)
    {
        if (IsGrounded)
        {
            coyoteTimer = coyoteTime;
        }
        else
        {
            coyoteTimer -= deltaTime;
        }

        if (Input.GetKeyDown(KeyCode.Space))
        {
            jumpBufferTimer = jumpBufferTime;
        }
        else
        {
            jumpBufferTimer -= deltaTime;
        }
    }

    // Escape remains the cursor-lock toggle.
    private void HandleCursorToggle()
    {
        if (!Input.GetKeyDown(KeyCode.Escape))
        {
            return;
        }

        if (Cursor.lockState == CursorLockMode.Locked)
        {
            UnlockCursor();
        }
        else
        {
            LockCursor();
        }
    }

    private static void LockCursor()
    {
        Cursor.lockState = CursorLockMode.Locked;
        Cursor.visible = false;
    }

    private static void UnlockCursor()
    {
        Cursor.lockState = CursorLockMode.None;
        Cursor.visible = true;
    }

    private static float NormalizeAngle(float angle)
    {
        return angle > 180f ? angle - 360f : angle;
    }

    private void OnValidate()
    {
        // Prevent invalid Inspector values.
        walkSpeed = Mathf.Max(0f, walkSpeed);
        sprintSpeed = Mathf.Max(walkSpeed, sprintSpeed);
        gravity = Mathf.Max(0.01f, gravity);
        terminalVelocity = Mathf.Max(0f, terminalVelocity);
        upDownLookLimit = Mathf.Clamp(
            upDownLookLimit,
            1f,
            90f
        );
    }
}
